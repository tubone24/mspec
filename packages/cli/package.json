{
  "name": "@mspec/cli",
  "version": "0.1.2",
  "description": "mspec - Spec-Driven Development framework CLI for Claude Code",
  "type": "module",
  "bin": {
    "mspec": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.5.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8",
    "picocolors": "^1.1.0",
    "mdast-util-to-string": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "tubone24",
  "homepage": "https://github.com/tubone24/mspec#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tubone24/mspec.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/tubone24/mspec/issues"
  },
  "keywords": [
    "spec-driven-development",
    "claude-code",
    "cli",
    "tdd",
    "mspec"
  ]
}
