{
  "name": "@mspec/web-ui",
  "version": "0.1.1",
  "description": "MSPEC Web UI — visual dashboard for the mspec workflow",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test tests/e2e/",
    "screenshots": "playwright test tests/screenshots/ --project=chromium",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "mermaid": "^11.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.0.2",
    "react-shiki": "^0.7.4",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.29.2",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@fastify/static": "^9.1.1",
    "@mspec/cli": "workspace:*",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "fastify": "^5.2.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "tubone24",
  "homepage": "https://tubone24.github.io/mspec/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tubone24/mspec.git",
    "directory": "packages/web-ui"
  },
  "bugs": {
    "url": "https://github.com/tubone24/mspec/issues"
  },
  "keywords": [
    "mspec",
    "spec-driven-development",
    "claude-code",
    "dashboard",
    "web-ui",
    "react",
    "tdd",
    "workflow-visualization"
  ]
}
